{# Formulário de cadastro/edição de carro da frota (com upload de foto) #}
{% set is_new = item.isNewItem() %}

<div class="carbooking-carform">
    <form method="post" action="{{ web_dir }}/front/car.form.php" enctype="multipart/form-data">

        {% if not is_new %}
            <input type="hidden" name="id" value="{{ item.fields['id'] }}">
        {% endif %}
        <input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token() }}">

        <div class="row">
            <div class="col-12 col-md-4 carbooking-carform__photo">
                <div class="carbooking-photo-preview">
                    {% if picture_url %}
                        <img src="{{ picture_url }}" alt="{{ item.fields['name'] }}">
                    {% else %}
                        <svg viewBox="0 0 260 140" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Carro">
                            <defs>
                                <linearGradient id="bform" x1="0" y1="0" x2="0" y2="1">
                                    <stop offset="0" stop-color="#4f8ef0"/><stop offset="1" stop-color="#1d4ed8"/>
                                </linearGradient>
                                <linearGradient id="gform" x1="0" y1="0" x2="0" y2="1">
                                    <stop offset="0" stop-color="#dbeafe"/><stop offset="1" stop-color="#93c5fd"/>
                                </linearGradient>
                                <radialGradient id="sform" cx="0.5" cy="0.5" r="0.5">
                                    <stop offset="0" stop-color="rgba(15,23,42,0.28)"/><stop offset="1" stop-color="rgba(15,23,42,0)"/>
                                </radialGradient>
                            </defs>
                            <ellipse cx="130" cy="120" rx="98" ry="12" fill="url(#sform)"/>
                            <path d="M22 100 L22 84 Q24 74 40 72 L70 70 Q80 70 86 60 L98 45 Q101 41 110 41 L166 41 Q177 41 183 49 L195 67 Q198 71 207 71 L224 72 Q238 74 238 86 L238 100 Z" fill="url(#bform)" stroke="#1e3a8a" stroke-width="1.5"/>
                            <path d="M40 73 L70 71 Q80 71 86 61 L98 46 Q101 42 110 42 L150 42 L150 47 L112 47 Q104 47 101 51 L90 66 Q84 74 72 74 L42 76 Z" fill="rgba(255,255,255,0.22)"/>
                            <path d="M96 58 L106 47 L131 47 L131 58 Z" fill="url(#gform)"/>
                            <path d="M137 47 L163 47 Q172 47 176 54 L179 58 L137 58 Z" fill="url(#gform)"/>
                            <rect x="232" y="78" width="8" height="7" rx="2" fill="#fca5a5"/>
                            <path d="M22 86 q-3 1 -3 5 l0 4 q0 2 4 2 l4 0 0 -4 q0 -4 -5 -11 Z" fill="#fde68a"/>
                            <line x1="40" y1="100" x2="238" y2="100" stroke="#1e3a8a" stroke-width="2" opacity="0.5"/>
                            <g><circle cx="74" cy="100" r="17" fill="#1f2937"/><circle cx="74" cy="100" r="9.5" fill="#e5e7eb"/><circle cx="74" cy="100" r="3.5" fill="#9ca3af"/></g>
                            <g><circle cx="190" cy="100" r="17" fill="#1f2937"/><circle cx="190" cy="100" r="9.5" fill="#e5e7eb"/><circle cx="190" cy="100" r="3.5" fill="#9ca3af"/></g>
                        </svg>
                    {% endif %}
                </div>
                <label class="form-label">{{ __('Foto do carro', 'carbooking') }}</label>
                <input type="file" name="picture" accept="image/*" class="form-control">
                <small class="text-muted">{{ __('JPG, PNG, WEBP ou GIF.', 'carbooking') }}</small>
            </div>

            <div class="col-12 col-md-8">
                <div class="mb-3">
                    <label class="form-label" for="car-name">{{ __('Modelo', 'carbooking') }}</label>
                    <input type="text" class="form-control" id="car-name" name="name"
                           value="{{ item.fields['name'] }}" required
                           placeholder="{{ __('Ex.: Fiat Strada', 'carbooking') }}">
                </div>

                <div class="row">
                    <div class="col-6 mb-3">
                        <label class="form-label" for="car-plate">{{ __('Placa', 'carbooking') }}</label>
                        <input type="text" class="form-control" id="car-plate" name="plate"
                               value="{{ item.fields['plate'] }}" placeholder="ABC1D23">
                    </div>
                    <div class="col-6 mb-3">
                        <label class="form-label" for="car-year">{{ __('Ano', 'carbooking') }}</label>
                        <input type="number" class="form-control" id="car-year" name="model_year"
                               value="{{ item.fields['model_year'] ?: '' }}" min="1950" max="2100" placeholder="2024">
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="car-active">{{ __('Disponível para agendamento', 'carbooking') }}</label>
                    <select class="form-select" id="car-active" name="is_active">
                        <option value="1" {{ item.fields['is_active'] ? 'selected' : '' }}>{{ __('Sim', 'carbooking') }}</option>
                        <option value="0" {{ not item.fields['is_active'] ? 'selected' : '' }}>{{ __('Não', 'carbooking') }}</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="car-comment">{{ __('Observações', 'carbooking') }}</label>
                    <textarea class="form-control" id="car-comment" name="comment" rows="2">{{ item.fields['comment'] }}</textarea>
                </div>
            </div>
        </div>

        <div class="carbooking-formactions">
            {% if is_new %}
                <button type="submit" name="add" value="1" class="btn btn-primary">
                    <i class="ti ti-plus"></i> {{ _x('button', 'Add') }}
                </button>
            {% else %}
                <button type="submit" name="update" value="1" class="btn btn-primary">
                    <i class="ti ti-device-floppy"></i> {{ _x('button', 'Save') }}
                </button>
                <button type="submit" name="purge" value="1" class="btn btn-outline-danger"
                        onclick="return confirm('{{ __('Excluir definitivamente este carro?', 'carbooking') }}');">
                    <i class="ti ti-trash"></i> {{ _x('button', 'Delete permanently') }}
                </button>
            {% endif %}
        </div>
    </form>
</div>
