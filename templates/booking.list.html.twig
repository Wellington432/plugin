{# Lista de agendamentos por status + tabela de chegadas (sem macro) #}

<div id="carbooking-booking-list" class="carbooking-agenda">

    {# ---------- Abas ---------- #}
    <div class="carbooking-tabs">
        <button type="button" class="carbooking-back" data-home="{{ web_dir }}/front/calendar.php"><i class="ti ti-arrow-left"></i> {{ __('Voltar', 'carbooking') }}</button>
        <a class="carbooking-tab" href="{{ web_dir }}/front/calendar.php"><i class="ti ti-calendar-month"></i> {{ __('Calendário', 'carbooking') }}</a>
        <span class="carbooking-tab is-active"><i class="ti ti-list-check"></i> {{ __('Agendamentos', 'carbooking') }}</span>
        {% if can_manage_cars %}
            <a class="carbooking-tab" href="{{ web_dir }}/front/car.php"><i class="ti ti-car"></i> {{ __('Frota', 'carbooking') }}</a>
        {% endif %}
        {% if can_view_analytics %}
            <a class="carbooking-tab" href="{{ web_dir }}/front/analytics.php"><i class="ti ti-chart-pie"></i> {{ __('Análise', 'carbooking') }}</a>
        {% endif %}
        <a class="carbooking-tab" href="{{ web_dir }}/front/history.php"><i class="ti ti-history"></i> {{ __('Histórico', 'carbooking') }}</a>
        <span class="carbooking-build">v1.0.61</span>
    </div>

    {# ---------- Como funciona (passo a passo simples) ---------- #}
    <div class="carbooking-help">
        <span class="carbooking-help__step"><b>1</b> {{ __('Pendentes esperam aprovação', 'carbooking') }}</span>
        <i class="ti ti-arrow-right"></i>
        <span class="carbooking-help__step"><b>2</b> {{ __('Aprovados estão liberados', 'carbooking') }}</span>
        <i class="ti ti-arrow-right"></i>
        <span class="carbooking-help__step"><b>3</b> {{ __('Ao voltar, marque a chegada', 'carbooking') }}</span>
    </div>

    {# ---------- Notificação para o aprovador ---------- #}
    {% if can_approve and pending_count > 0 %}
        <div class="carbooking-notify">
            <i class="ti ti-bell-ringing"></i>
            <span>{{ pending_count }}
                {{ pending_count == 1
                    ? __('agendamento pendente aguardando sua aprovação.', 'carbooking')
                    : __('agendamentos pendentes aguardando sua aprovação.', 'carbooking') }}</span>
        </div>
    {% endif %}

    {# ---------- Três listas por status ---------- #}
    <div class="carbooking-blist-cols">

        <section class="carbooking-blist-col col-pending">
            <header class="carbooking-blist-head"><i class="ti ti-clock"></i> {{ __('Pendentes', 'carbooking') }} <span class="carbooking-blist-count">{{ groups.pending|length }}</span></header>
            {% if groups.pending is empty %}
                <p class="carbooking-blist-empty">{{ __('Nenhum pendente.', 'carbooking') }}</p>
            {% else %}
                {% for b in groups.pending %}{% include '@carbooking/booking.row.html.twig' with {'b': b, 'web_dir': web_dir, 'can_approve': can_approve, 'csrf': csrf} %}{% endfor %}
            {% endif %}
        </section>

        <section class="carbooking-blist-col col-approved">
            <header class="carbooking-blist-head"><i class="ti ti-circle-check"></i> {{ __('Aprovados', 'carbooking') }} <span class="carbooking-blist-count">{{ groups.approved|length }}</span></header>
            {% if groups.approved is empty %}
                <p class="carbooking-blist-empty">{{ __('Nenhum aprovado.', 'carbooking') }}</p>
            {% else %}
                {% for b in groups.approved %}{% include '@carbooking/booking.row.html.twig' with {'b': b, 'web_dir': web_dir, 'can_approve': can_approve, 'csrf': csrf} %}{% endfor %}
            {% endif %}
        </section>

        <section class="carbooking-blist-col col-rejected">
            <header class="carbooking-blist-head"><i class="ti ti-circle-x"></i> {{ __('Recusados / Cancelados', 'carbooking') }} <span class="carbooking-blist-count">{{ groups.rejected|length + groups.cancelled|length }}</span></header>
            {% if groups.rejected is empty and groups.cancelled is empty %}
                <p class="carbooking-blist-empty">{{ __('Nada aqui.', 'carbooking') }}</p>
            {% else %}
                {% for b in groups.rejected %}{% include '@carbooking/booking.row.html.twig' with {'b': b, 'web_dir': web_dir, 'can_approve': can_approve, 'csrf': csrf} %}{% endfor %}
                {% for b in groups.cancelled %}{% include '@carbooking/booking.row.html.twig' with {'b': b, 'web_dir': web_dir, 'can_approve': can_approve, 'csrf': csrf} %}{% endfor %}
            {% endif %}
        </section>

    </div>

    {# ---------- Tabela de chegadas ---------- #}
    <section id="carbooking-arrived-section" class="carbooking-arrived-section">
        <header class="carbooking-blist-head carbooking-arrived-head">
            <i class="ti ti-flag-check"></i> {{ __('Chegados', 'carbooking') }}
            <span class="carbooking-blist-count">{{ groups.arrived|length }}</span>
        </header>
        {% if groups.arrived is empty %}
            <p class="carbooking-blist-empty">{{ __('Nenhuma chegada registrada.', 'carbooking') }}</p>
        {% else %}
            <table class="carbooking-arrived-table">
                <thead>
                    <tr>
                        <th>{{ __('Data saída', 'carbooking') }}</th>
                        <th>{{ __('Carro', 'carbooking') }}</th>
                        <th>{{ __('Solicitante', 'carbooking') }}</th>
                        <th>{{ __('Setor', 'carbooking') }}</th>
                        <th>{{ __('Destino', 'carbooking') }}</th>
                        <th>{{ __('Chegada', 'carbooking') }}</th>
                        <th>{{ __('Folha', 'carbooking') }}</th>
                    </tr>
                </thead>
                <tbody>
                {% for b in groups.arrived %}
                    <tr>
                        <td><b>{{ b.departure|slice(8,2) }}/{{ b.departure|slice(5,2) }}</b> {{ b.departure|slice(11,5) }}</td>
                        <td>{{ b.car }}</td>
                        <td>{{ b.user }}</td>
                        <td>{{ b.sector }}</td>
                        <td>{{ b.destination ?: '—' }}</td>
                        <td class="ok">
                            {% if b.returned_at %}
                                <i class="ti ti-circle-check"></i>
                                {{ b.returned_at|slice(8,2) }}/{{ b.returned_at|slice(5,2) }} {{ b.returned_at|slice(11,5) }}
                            {% else %}—{% endif %}
                        </td>
                        <td>
                            {% if b.has_sheet %}
                                <a class="carbooking-btn-info" href="{{ web_dir }}/front/sheet.php?id={{ b.id }}"><i class="ti ti-download"></i> {{ __('Baixar', 'carbooking') }}</a>
                            {% else %}—{% endif %}
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </section>

</div>
