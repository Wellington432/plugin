{# Linha de um agendamento (sem macro). Espera: b, web_dir, can_approve #}
<div class="carbooking-blist-item s-{{ b.status }}">
    <div class="carbooking-blist-item__date">
        <span class="carbooking-blist-day">{{ b.departure|slice(8,2) }}/{{ b.departure|slice(5,2) }}</span>
        <span class="carbooking-blist-time">{{ b.departure|slice(11,5) }}{% if b.arrival %} &rarr; {{ b.arrival|slice(11,5) }}{% endif %}</span>
    </div>
    <div class="carbooking-blist-item__body">
        <strong>{{ b.car }}</strong>
        <div class="carbooking-blist-meta"><i class="ti ti-user"></i> {{ b.user }} &nbsp;·&nbsp; <i class="ti ti-steering-wheel"></i> {{ b.driver ?: '—' }}{% if b.has_companion %} <span class="text-muted">+ {{ b.companion ?: 1 }} {{ __('acompanhante(s)', 'carbooking') }}</span>{% endif %}</div>
        {% if b.destination %}<div class="carbooking-blist-meta"><i class="ti ti-map-pin"></i> {{ b.destination }}</div>{% endif %}
        {% if b.reason %}<div class="carbooking-blist-meta"><i class="ti ti-note"></i> {{ __('Motivo', 'carbooking') }}: {{ b.reason }}</div>{% endif %}
        {% if b.returned_at %}<div class="carbooking-blist-meta ok"><i class="ti ti-circle-check"></i> {{ __('Concluído em', 'carbooking') }} {{ b.returned_at|slice(8,2) }}/{{ b.returned_at|slice(5,2) }} {{ b.returned_at|slice(11,5) }}</div>{% endif %}
        {% if b.status == 4 and b.note %}<div class="carbooking-blist-meta no"><i class="ti ti-info-circle"></i> {{ __('Motivo', 'carbooking') }}: {{ b.note }}</div>{% endif %}
    </div>
    <div class="carbooking-blist-item__side">
        <span class="carbooking-chip status-{{ b.status == 2 ? 'approved' : (b.status == 3 ? 'rejected' : (b.status == 4 ? 'rejected' : 'pending')) }}">{{ b.status_label }}</span>

        <div class="carbooking-blist-actions">
            {% if b.status in [1, 2] and (can_approve or b.can_cancel) %}
                <button type="button" class="carbooking-btn-edit"
                        data-cb-edit
                        data-bform="{{ web_dir }}/front/booking.form.php"
                        data-csrf="{{ csrf }}"
                        data-booking="{{ {'id': b.id, 'car': b.car, 'driver': b.driver, 'has_companion': b.has_companion, 'companion': b.companion, 'departure': b.departure, 'arrival': b.arrival, 'destination': b.destination, 'reason': b.reason, 'status': b.status}|json_encode|e('html_attr') }}"><i class="ti ti-edit"></i> {{ __('Editar', 'carbooking') }}</button>
            {% endif %}

            {% if b.status == 1 and can_approve %}
                {% if b.conflict %}
                    <button type="button" class="carbooking-btn-approve carbooking-btn-analyze"
                            data-cb-analyze
                            data-id="{{ b.id }}"
                            data-bform="{{ web_dir }}/front/booking.form.php"
                            data-csrf="{{ csrf }}"
                            data-new="{{ {'id': b.id, 'car': b.car, 'user': b.user, 'driver': b.driver, 'departure': b.departure, 'arrival': b.arrival, 'destination': b.destination, 'reason': b.reason}|json_encode|e('html_attr') }}"
                            data-conflicts="{{ b.conflict_with|json_encode|e('html_attr') }}">
                        <i class="ti ti-alert-triangle"></i> {{ __('Analisar', 'carbooking') }}
                    </button>
                {% else %}
                    <form method="post" action="{{ web_dir }}/front/booking.form.php"
                          data-cb-approve
                          data-user="{{ b.user }}" data-driver="{{ b.driver }}" data-car="{{ b.car }}"
                          data-departure="{{ b.departure }}" data-arrival="{{ b.arrival }}"
                          data-destination="{{ b.destination }}" data-reason="{{ b.reason }}"
                          data-companion="{% if b.has_companion %}{{ b.companion ?: '1' }}{% endif %}">
                        <input type="hidden" name="id" value="{{ b.id }}">
                        <input type="hidden" name="approve" value="1">
                        <input type="hidden" name="_glpi_csrf_token" value="{{ csrf }}">
                        <button type="submit" class="carbooking-btn-approve"><i class="ti ti-check"></i> {{ __('Aprovar', 'carbooking') }}</button>
                    </form>
                {% endif %}
            {% endif %}

            {% if b.status == 2 and can_approve and not b.returned_at %}
                <button type="button" class="carbooking-btn-arrive"
                        data-cb-arrive data-id="{{ b.id }}"
                        data-bform="{{ web_dir }}/front/booking.form.php"
                        data-csrf="{{ csrf }}">
                    <i class="ti ti-flag-check"></i> {{ __('Finalizar viagem', 'carbooking') }}
                </button>
            {% endif %}

            {% if b.has_sheet %}
                <a class="carbooking-btn-info" href="{{ web_dir }}/front/sheet.php?id={{ b.id }}"><i class="ti ti-download"></i> {{ __('Baixar folha', 'carbooking') }}</a>
            {% endif %}

            {% if b.can_cancel %}
                <button type="button" class="carbooking-btn-cancel"
                        data-cb-cancel data-id="{{ b.id }}"
                        data-bform="{{ web_dir }}/front/booking.form.php"
                        data-csrf="{{ csrf }}">
                    <i class="ti ti-ban"></i> {{ __('Cancelar', 'carbooking') }}
                </button>
            {% endif %}
        </div>
    </div>
</div>
